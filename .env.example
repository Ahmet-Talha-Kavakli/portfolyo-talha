# Talha portfolyo — ortam değişkenleri
# Bu dosyayı `.env.local` olarak kopyalayıp gerçek değerleri gir.
# .env.local git'e GİRMEZ; .env.example git'e girer (örnek şablon).

# Contact formu — Resend (Faz 6)
# https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# Form mesajlarının düşeceği alıcı e-posta
CONTACT_TO_EMAIL=your@email.com
# Resend "from" adresi (doğrulanmış domain veya onboarding@resend.dev)
CONTACT_FROM_EMAIL=onboarding@resend.dev

# fal.ai — yalnız `scripts/frames.mjs` üretim adımında kullanılır (Faz 7)
# Tarayıcıya GİTMEZ; sadece yerel/CI script.
FAL_KEY=
